# ─── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
# REQUIRED: allowlists (comma-separated IDs). Empty = deny all.
ALLOWED_USERS=123456789,987654321
ALLOWED_GROUPS=-1001234567890,-1009876543210

# ─── Playwright / Gemini ─────────────────────────────────────
# Set to true for servers without display (requires Xvfb or similar)
PLAYWRIGHT_HEADLESS=false

# Optional: path to Chrome executable (auto-detected if omitted)
# PLAYWRIGHT_EXECUTABLE_PATH=/usr/bin/google-chrome-stable

# Optional: browser channel (chrome, msedge, chromium)
# PLAYWRIGHT_BROWSER_CHANNEL=chrome

# Profile directory name (inside .playwright/profiles/<namespace>/)
GEMINI_PROFILE_DIR=_shared

# Optional: custom base directory for Playwright profiles
# PLAYWRIGHT_BASE_PROFILE_DIR=.playwright/profiles

# ─── Streaming tuning ─────────────────────────────────────────
STREAM_POLL_INTERVAL_MS=700
STREAM_STABLE_TICKS=4
STREAM_FIRST_CHUNK_TIMEOUT_MS=25000
STREAM_MAX_DURATION_MS=90000

# ─── Rate limiting & session management ──────────────────────
# Minimum cooldown between requests per user (ms). 0 = no limit.
RATE_LIMIT_MS=3000
# Idle timeout before a session tab is closed (ms). Conversation is preserved.
SESSION_IDLE_TIMEOUT_MS=1800000
# Maximum concurrent browser tabs. Oldest idle tabs evicted when exceeded.
MAX_SESSION_TABS=20

# ─── System prompt ────────────────────────────────────────────
# Reserved for future prompt injection; currently loaded in config but not
# automatically injected into Gemini by the runtime flow.
# SYSTEM_PROMPT=Sei TeGem, un assistente AI su Telegram...
